  sourceFileHash        String
  sourceFileSizeBytes   Int
  storagePath           String
  mappingSnapshot       Json
  uploadedBy            String
  uploadedAt            DateTime @default(now())
  status                ImportBatchStatus @default(uploading)
  rowCountSource        Int @default(0)
  rowCountImported      Int @default(0)
  rowCountExcluded      Int @default(0)
  rowCountFailed        Int @default(0)
