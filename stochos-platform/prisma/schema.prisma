enum ImportBatchStatus {
  uploading
  parsing
  mapping
  validating
  importing
  complete
  failed
  rolled_back
}

enum ImportValidationStatus {
  passed
  passed_with_warnings
  failed
}

model ImportBatch {
  id                    String   @id @default(uuid())
  organizationId        String
  gridId                String
  pipelineId            String
