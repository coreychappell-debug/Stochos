// =============================================================================
// Stochos Platform — Prisma Schema
// =============================================================================
// Lottery-agnostic data model for contract management, shared dimensions,
// and user authentication.
//
// Design principles:
//   - UUIDs as primary keys (portable, no sequence conflicts)
//   - Stochos-owned identifiers; external codes are optional mappings
//   - Every mutation logged in AuditLog
//   - JSONB for flexible terms/metadata without schema churn
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// SHARED DIMENSIONS
// ─────────────────────────────────────────────

model Jurisdiction {
  id                   String   @id @default(uuid())
  name                 String   // "New York Lottery"
  abbreviation         String   @unique // "NY"
  currency             String   @default("USD")
  fiscalYearStartMonth Int      @default(4) @map("fiscal_year_start_month")
  timezone             String   @default("America/New_York")
  status               String   @default("active")
  createdAt            DateTime @default(now()) @map("created_at")

  products  Product[]
  vendors   Vendor[]
  contracts Contract[]
  users     User[]
  campaigns Campaign[]
  instantTicketPlans InstantTicketPlan[]
  vehicles  Vehicle[]
  assets    Asset[]
  crmRegions CrmRegion[]

  @@map("jurisdictions")
}

model Product {
  id             String       @id @default(uuid())
  jurisdictionId String       @map("jurisdiction_id")
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id])
  name           String       // "Mega Millions", "Cash4Life", etc.
  category       String       // 'draw_game', 'instant', 'monitor', 'marketing_campaign'
  type           String?      // 'lotto_jackpot', 'pick_3', 'scratch_off', etc.
  price          Decimal?     @db.Decimal(10, 2)
  status         String       @default("active")
  externalCode   String?      @map("external_code")   // e.g., 'mega', 'powerball'
  externalSource String?      @map("external_source")  // e.g., 'ny_game_dim'
  createdAt      DateTime     @default(now()) @map("created_at")

  lineItems ContractLineItem[]
  campaigns Campaign[]       @relation("CampaignProducts")
  instantTicketGames InstantTicketGame[]

  @@map("products")
}

model Vendor {
  id             String        @id @default(uuid())
  jurisdictionId String?       @map("jurisdiction_id")
  jurisdiction   Jurisdiction? @relation(fields: [jurisdictionId], references: [id])
  name           String
  type           String        // 'lead_agency', 'media_buyer', 'printer', 'specialty', 'research'
  status         String        @default("active")
  contactName    String?       @map("contact_name")
  contactEmail   String?       @map("contact_email")
  contactPhone   String?       @map("contact_phone")
  address        String?
  certifications String[]      @default([])
  notes          String?
  taxId          String?       @map("tax_id")
  website        String?
  paymentTerms   String?       @map("payment_terms")
  classification String?       // e.g. "MWBE", "Small Business"
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  contracts Contract[]
  campaigns  Campaign[]
  channels   CampaignChannel[]
  assets     CampaignAsset[]
  milestones CampaignMilestone[]
  instantTicketGames          InstantTicketGame[]
  instantTicketVendorPricings InstantTicketVendorPricing[]
  instantTicketMarketingItems InstantTicketMarketingItem[]

  @@map("vendors")
}

// ─────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────

model Role {
  id          String @id @default(uuid())
  name        String @unique // 'admin', 'marketing_manager', 'procurement_officer', 'analyst'
  permissions Json   @default("{}") // {"contracts": "write", "analytics": "read"}

  users User[]

  @@map("roles")
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  name           String
  passwordHash   String        @map("password_hash")
  roleId         String        @map("role_id")
  role           Role          @relation(fields: [roleId], references: [id])
  jurisdictionId String?       @map("jurisdiction_id")
  jurisdiction   Jurisdiction? @relation(fields: [jurisdictionId], references: [id])
  lastLogin      DateTime?     @map("last_login")
  status         String        @default("active")
  createdAt      DateTime      @default(now()) @map("created_at")

  contractsCreated Contract[] @relation("ContractCreatedBy")
  invoicesApproved Invoice[]  @relation("InvoiceApprovedBy")
  approvals        Approval[] @relation("ApprovalApprover")
  auditLogs        AuditLog[]
  campaignsCreated Campaign[]
  contractAccess   ContractAccess[]
  vehicles         Vehicle[]
  assets           Asset[]

  managerId          String?                   @map("manager_id")
  manager            User?                     @relation("ManagerStaff", fields: [managerId], references: [id])
  staff              User[]                    @relation("ManagerStaff")
  crmRoutes          CrmRoute[]                @relation("RouteRepresentative")
  crmVisits          CrmVisit[]
  resolvedExceptions CrmDiscrepancyException[] @relation("DiscrepancyResolver")
  crmImportBatches   CrmImportBatch[]

  @@map("users")
}

// ─────────────────────────────────────────────
// CONTRACT MANAGEMENT
// ─────────────────────────────────────────────

model Contract {
  id             String       @id @default(uuid())
  jurisdictionId String       @map("jurisdiction_id")
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id])
  vendorId       String       @map("vendor_id")
  vendor         Vendor       @relation(fields: [vendorId], references: [id])
  parentId       String?      @map("parent_id")
  parent         Contract?    @relation("ContractHierarchy", fields: [parentId], references: [id])
  children       Contract[]   @relation("ContractHierarchy")
  title          String
  type           String       // 'lead_agency', 'media_buying', 'instant_ticket', 'specialty', 'zero_base'
  status         String       @default("draft") // 'draft', 'pending_approval', 'active', 'expired', 'terminated'
  startDate      DateTime?    @map("start_date") @db.Date
  endDate        DateTime?    @map("end_date") @db.Date
  noticeDate     DateTime?    @map("notice_date") @db.Date
  totalValue     Decimal?     @map("total_value") @db.Decimal(14, 2)
  budgetCap      Decimal?     @map("budget_cap") @db.Decimal(14, 2)
  terms          Json?        @default("{}") // flexible key-value
  createdById    String       @map("created_by")
  createdBy      User         @relation("ContractCreatedBy", fields: [createdById], references: [id])
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  lineItems      ContractLineItem[]
  amendments     ContractAmendment[]
  compliance     ContractCompliance[]
  invoices       Invoice[]
  campaigns      Campaign[]
  purchaseOrders PurchaseOrder[]
  accessList     ContractAccess[]

  @@map("contracts")
}

model ContractLineItem {
  id              String   @id @default(uuid())
  contractId      String   @map("contract_id")
  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  productId       String?  @map("product_id")
  product         Product? @relation(fields: [productId], references: [id])
  description     String
  deliverableType String?  @map("deliverable_type") // 'media_placement', 'print_signage', 'creative', etc.
  budgetAmount    Decimal? @map("budget_amount") @db.Decimal(14, 2)
  spentAmount     Decimal  @default(0) @map("spent_amount") @db.Decimal(14, 2)
  quantity        Int?
  unitCost        Decimal? @map("unit_cost") @db.Decimal(10, 4)
  dueDate         DateTime? @map("due_date") @db.Date
  status          String   @default("pending") // 'pending', 'in_progress', 'delivered', 'invoiced', 'closed'
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")

  invoices Invoice[]

  @@map("contract_line_items")
}

model ContractAmendment {
  id              String   @id @default(uuid())
  contractId      String   @map("contract_id")
  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  amendmentNumber Int      @map("amendment_number")
  description     String?
  valueChange     Decimal  @default(0) @map("value_change") @db.Decimal(14, 2)
  newEndDate      DateTime? @map("new_end_date") @db.Date
  effectiveDate   DateTime? @map("effective_date") @db.Date
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("contract_amendments")
}

model ContractCompliance {
  id             String   @id @default(uuid())
  contractId     String   @map("contract_id")
  contract       Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  documentType   String   @map("document_type") // 'bond', 'insurance', 'nda', 'background_check', 'license'
  description    String?
  expirationDate DateTime? @map("expiration_date") @db.Date
  status         String   @default("pending") // 'pending', 'received', 'expired', 'waived'
  fileReference  String?  @map("file_reference")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("contract_compliance")
}

model Invoice {
  id            String            @id @default(uuid())
  contractId    String            @map("contract_id")
  contract      Contract          @relation(fields: [contractId], references: [id], onDelete: Cascade)
  lineItemId    String?           @map("line_item_id")
  lineItem      ContractLineItem? @relation(fields: [lineItemId], references: [id])
  invoiceNumber String?           @map("invoice_number")
  amount        Decimal           @db.Decimal(14, 2)
  description   String?
  submittedAt   DateTime?         @map("submitted_at") @db.Date
  approvedAt    DateTime?         @map("approved_at") @db.Date
  paidAt        DateTime?         @map("paid_at") @db.Date
  status        String            @default("submitted") // 'submitted', 'approved', 'rejected', 'paid'
  approvedById  String?           @map("approved_by")
  approvedBy    User?             @relation("InvoiceApprovedBy", fields: [approvedById], references: [id])
  notes         String?
  createdAt     DateTime          @default(now()) @map("created_at")

  @@map("invoices")
}

// ─────────────────────────────────────────────
// WORKFLOW
// ─────────────────────────────────────────────

model Approval {
  id         String    @id @default(uuid())
  entityType String    @map("entity_type") // 'contract', 'invoice', 'purchase_order'
  entityId   String    @map("entity_id")
  approverId String    @map("approver_id")
  approver   User      @relation("ApprovalApprover", fields: [approverId], references: [id])
  status     String    // 'pending', 'approved', 'rejected'
  comment    String?
  decidedAt  DateTime? @map("decided_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("approvals")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String   // 'create', 'update', 'delete', 'approve', 'reject'
  changes    Json?    @default("{}") // before/after diff
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("audit_log")
}

// ─────────────────────────────────────────────
// MARKETING CAMPAIGNS (MRM)
// ─────────────────────────────────────────────

model Campaign {
  id             String       @id @default(uuid())
  jurisdictionId String       @map("jurisdiction_id")
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id])
  vendorId       String       @map("vendor_id")
  vendor         Vendor       @relation(fields: [vendorId], references: [id])
  contractId     String?      @map("contract_id")
  contract       Contract?    @relation(fields: [contractId], references: [id])
  name           String
  objective      String?      @db.Text
  status         String       @default("planning") // 'planning', 'briefed', 'in_production', 'live', 'completed', 'cancelled'
  campaignType   String?      @map("campaign_type") // 'jackpot_awareness', 'new_game_launch', 'seasonal', 'brand', 'retail_activation', 'digital'
  totalBudget    Decimal?     @map("total_budget") @db.Decimal(14, 2)
  startDate      DateTime?    @map("start_date") @db.Date
  endDate        DateTime?    @map("end_date") @db.Date
  notes          String?      @db.Text
  createdById    String       @map("created_by")
  createdBy      User         @relation(fields: [createdById], references: [id])
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  channels   CampaignChannel[]
  assets     CampaignAsset[]
  milestones CampaignMilestone[]
  products   Product[]         @relation("CampaignProducts")

  @@map("campaigns")
}

model CampaignChannel {
  id           String    @id @default(uuid())
  campaignId   String    @map("campaign_id")
  campaign     Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  vendorId     String?   @map("vendor_id")
  vendor       Vendor?   @relation(fields: [vendorId], references: [id])
  channel      String    // 'tv', 'radio', 'digital_display', 'social_media', 'outdoor', 'pos_retail', 'print', 'events', 'sponsorship'
  description  String?
  status       String    @default("planned") // 'planned', 'active', 'paused', 'completed', 'cancelled'
  plannedSpend Decimal?  @map("planned_spend") @db.Decimal(14, 2)
  actualSpend  Decimal   @default(0) @map("actual_spend") @db.Decimal(14, 2)
  startDate    DateTime? @map("start_date") @db.Date
  endDate      DateTime? @map("end_date") @db.Date
  targetMarket String?   @map("target_market")
  kpiGoal      String?   @map("kpi_goal")
  impressions  BigInt?
  notes        String?   @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  assets       CampaignAsset[]
  milestones   CampaignMilestone[]

  @@map("campaign_channels")
}

model CampaignAsset {
  id                    String           @id @default(uuid())
  campaignId            String           @map("campaign_id")
  campaign              Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  channelId             String?          @map("channel_id")
  channel               CampaignChannel? @relation(fields: [channelId], references: [id])
  vendorId              String?          @map("vendor_id")
  vendor                Vendor?          @relation(fields: [vendorId], references: [id])
  
  name                  String           // renamed from assetName internally, or keep as name since it was name
  assetType             String           @map("asset_type") // 'video', 'static_image', 'html5', 'audio', 'copy'
  formatSpecs           String?          @map("format_specs") // e.g. 1920x1080, MP4, 30s
  language              String?          @default("English")
  
  status                String           @default("draft") // draft, in_review, approved, in_production, live, retired
  approvalStatus        String?          @map("approval_status") // e.g. pending_legal, approved, rejected
  reviewOwner           String?          @map("review_owner")
  
  dueDate               DateTime?        @map("due_date") @db.Date
  launchDate            DateTime?        @map("launch_date") @db.Date
  expirationDate        DateTime?        @map("expiration_date") @db.Date
  usageRightsExpiration DateTime?        @map("usage_rights_expiration") @db.Date
  
  assetUrl              String?          @map("asset_url")
  version               String           @default("v1")
  
  complianceNotes       String?          @map("compliance_notes") @db.Text
  notes                 String?          @db.Text
  
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")
  milestones            CampaignMilestone[]

  @@map("campaign_assets")
}

model CampaignMilestone {
  id            String           @id @default(uuid())
  campaignId    String           @map("campaign_id")
  campaign      Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  channelId     String?          @map("channel_id")
  channel       CampaignChannel? @relation(fields: [channelId], references: [id])
  assetId       String?          @map("asset_id")
  asset         CampaignAsset?   @relation(fields: [assetId], references: [id])
  vendorId      String?          @map("vendor_id")
  vendor        Vendor?          @relation(fields: [vendorId], references: [id])
  
  name          String
  milestoneType String           @map("milestone_type")
  owner         String?
  priority      String           @default("normal")
  status        String           @default("not_started")
  
  dueDate       DateTime?        @map("due_date") @db.Date
  completedDate DateTime?        @map("completed_date") @db.Date
  
  dependencyNotes String?        @map("dependency_notes") @db.Text
  blockerReason   String?        @map("blocker_reason") @db.Text
  notes           String?        @db.Text
  
  sortOrder     Int              @default(0) @map("sort_order")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  @@map("campaign_milestones")
}

// ─────────────────────────────────────────────
// INSTANT TICKET PLANNER
// ─────────────────────────────────────────────

model InstantTicketPlan {
  id             String       @id @default(uuid())
  jurisdictionId String       @map("jurisdiction_id")
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id])
  name           String       // "FY2027 Base Plan"
  fiscalYear     Int          @map("fiscal_year")
  totalSalesTarget     Decimal  @map("total_sales_target") @db.Decimal(14, 2)
  retailerCommPct      Decimal  @default(5.0) @map("retailer_comm_pct") @db.Decimal(5, 2)
  adminExpensePct      Decimal  @default(0.0) @map("admin_expense_pct") @db.Decimal(5, 2)
  sellThroughPct       Decimal  @default(98.0) @map("sell_through_pct") @db.Decimal(5, 2)
  status         String       @default("draft") // 'draft', 'submitted', 'approved', 'archived'
  notes          String?      @db.Text
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  scenarios InstantTicketScenario[]

  @@map("instant_ticket_plans")
}

model InstantTicketScenario {
  id             String            @id @default(uuid())
  planId         String            @map("plan_id")
  plan           InstantTicketPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  name           String            // "Base Plan", "Conservative", "Aggressive"
  sortOrder      Int               @default(0) @map("sort_order")
  denominations  Json              @default("[]") // [{price: 1, mixPercent: 10, isActive: true}, ...]
  createdAt      DateTime          @default(now()) @map("created_at")

  games          InstantTicketGame[]
  marketingItems InstantTicketMarketingItem[]

  @@map("instant_ticket_scenarios")
}

model InstantTicketGame {
  id                String                 @id @default(uuid())
  scenarioId        String                 @map("scenario_id")
  scenario          InstantTicketScenario  @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  vendorId          String?                @map("vendor_id")
  vendor            Vendor?                @relation(fields: [vendorId], references: [id])
  productId         String?                @map("product_id")
  product           Product?               @relation(fields: [productId], references: [id])
  gameNumber        String                 @map("game_number")
  name              String
  denomination      Int                    // 1, 2, 3, 5, 10, 20, 25, 30, 50
  ticketSize        String                 @default("4x4") @map("ticket_size")
  units             BigInt                 // e.g. 12000000
  payoutPercent     Decimal                @map("payout_percent") @db.Decimal(5, 2)
  topPrize          Decimal?               @map("top_prize") @db.Decimal(14, 2)
  // Lifecycle dates
  launchDate        DateTime?              @map("launch_date") @db.Date    // When the game goes on sale
  closeDate         DateTime?              @map("close_date") @db.Date     // When the game stops selling (closed to retail)
  endDate           DateTime?              @map("end_date") @db.Date       // Final claim deadline
  // Procurement
  poNumber          String?                @map("po_number")
  poDate            DateTime?              @map("po_date") @db.Date
  receiptDate       DateTime?              @map("receipt_date") @db.Date
  deliveryStatus    String                 @default("planned") @map("delivery_status") // 'planned', 'ordered', 'in_production', 'shipped', 'received'
  sortOrder         Int                    @default(0) @map("sort_order")
  createdAt         DateTime               @default(now()) @map("created_at")

  features InstantTicketGameFeature[]

  @@map("instant_ticket_games")
}

model InstantTicketGameFeature {
  id         String            @id @default(uuid())
  gameId     String            @map("game_id")
  game       InstantTicketGame @relation(fields: [gameId], references: [id], onDelete: Cascade)
  featureName String           @map("feature_name") // "Holographic Foil", "Scented Ink", etc.

  @@unique([gameId, featureName])
  @@map("instant_ticket_game_features")
}

model InstantTicketMarketingItem {
  id           String                 @id @default(uuid())
  scenarioId   String                 @map("scenario_id")
  scenario     InstantTicketScenario  @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  vendorId     String?                @map("vendor_id")
  vendor       Vendor?                @relation(fields: [vendorId], references: [id])
  name         String
  description  String?
  cost         Decimal                @db.Decimal(14, 2)
  category     String?                // 'pos_display', 'digital_campaign', 'insert', 'signage'
  sortOrder    Int                    @default(0) @map("sort_order")
  createdAt     DateTime               @default(now()) @map("created_at")

  @@map("instant_ticket_marketing_items")
}

model InstantTicketVendorPricing {
  id          String  @id @default(uuid())
  vendorId    String  @map("vendor_id")
  vendor      Vendor  @relation(fields: [vendorId], references: [id])
  costModel   String  @map("cost_model") // 'per_thousand' or 'percent_of_sales'
  ticketSize  String  @map("ticket_size") // '2.4x4', '4x4', '6x4', '8x4', '12x8', '12x12'
  baseCost    Decimal @map("base_cost") @db.Decimal(10, 4)
  minQuantity BigInt  @default(0) @map("min_quantity") // volume tier threshold
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([vendorId, ticketSize, minQuantity])
  @@map("instant_ticket_vendor_pricing")
}

model PurchaseOrder {
  id             String    @id @default(uuid())
  contractId     String    @map("contract_id")
  contract       Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  poNumber       String    @unique @map("po_number")
  description    String?
  amount         Decimal   @db.Decimal(14, 2)
  status         String    @default("issued") // 'draft', 'issued', 'received', 'rejected', 'disputed', 'closed'
  issuedDate     DateTime? @map("issued_date") @db.Date
  deliveryDate   DateTime? @map("delivery_date") @db.Date
  notes          String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("purchase_orders")
}

model ContractAccess {
  id         String   @id @default(uuid())
  contractId String   @map("contract_id")
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission String   @default("read") // 'read', 'write'
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([contractId, userId])
  @@map("contract_access")
}

model Vehicle {
  id             String        @id @default(uuid())
  jurisdictionId String        @map("jurisdiction_id")
  jurisdiction   Jurisdiction  @relation(fields: [jurisdictionId], references: [id])
  make           String        // "Ford", "Chevrolet"
  model          String        // "Explorer", "Bolt"
  year           Int
  vin            String        @unique
  licensePlate   String        @map("license_plate")
  status         String        @default("active") // 'active', 'maintenance', 'retired'
  mileage        Int           @default(0)
  lastService    DateTime?     @map("last_service") @db.Date
  assignedToId   String?       @map("assigned_to_id")
  assignedTo     User?         @relation(fields: [assignedToId], references: [id])
  notes          String?       @db.Text
  disposalDate   DateTime?     @map("disposal_date") @db.Date
  disposalMethod String?       @map("disposal_method") // 'sold', 'scrapped', 'donated', 'other'
  salePrice      Decimal?      @map("sale_price") @db.Decimal(10, 2)
  usefulLifeMonths Int?        @map("useful_life_months") @default(120) // 10 years default
  usefulLifeMiles  Int?        @map("useful_life_miles") @default(100000) // 100k miles default
  value          Decimal?      @db.Decimal(10, 2)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@map("vehicles")
}

model Asset {
  id             String        @id @default(uuid())
  jurisdictionId String        @map("jurisdiction_id")
  jurisdiction   Jurisdiction  @relation(fields: [jurisdictionId], references: [id])
  assetTag       String        @unique @map("asset_tag") // unique barcode/sticker ID
  name           String        // "Dell Latitude 5440"
  category       String        // 'computer', 'mobile', 'scanner', 'peripheral', 'furniture', 'other'
  serialNumber   String?       @map("serial_number")
  status         String        @default("available") // 'available', 'assigned', 'repair', 'retired'
  value          Decimal?      @db.Decimal(10, 2)
  assignedToId   String?       @map("assigned_to_id")
  assignedTo     User?         @relation(fields: [assignedToId], references: [id])
  purchaseDate   DateTime?     @map("purchase_date") @db.Date
  notes          String?       @db.Text
  disposalDate   DateTime?     @map("disposal_date") @db.Date
  disposalMethod String?       @map("disposal_method") // 'sold', 'scrapped', 'donated', 'other'
  salePrice      Decimal?      @map("sale_price") @db.Decimal(10, 2)
  usefulLifeMonths Int?        @map("useful_life_months") @default(36) // 3 years default (36 months)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@map("assets")
}

// =============================================================================
// CRM / SALES OVERLAY MODELS
// =============================================================================

model CrmRegion {
  id             String       @id @default(uuid())
  jurisdictionId String       @map("jurisdiction_id")
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id])
  name           String       // e.g., "Region 1 - Metro"
  code           String       @unique // e.g., "REG-1"
  createdAt      DateTime     @default(now()) @map("created_at")
  districts      CrmDistrict[]

  @@map("crm_regions")
}

model CrmDistrict {
  id        String     @id @default(uuid())
  regionId  String     @map("region_id")
  region    CrmRegion  @relation(fields: [regionId], references: [id], onDelete: Cascade)
  name      String     // e.g., "District 12 - Long Island"
  code      String     @unique // e.g., "DIST-12"
  createdAt DateTime   @default(now()) @map("created_at")
  routes    CrmRoute[]

  @@map("crm_districts")
}

model CrmRoute {
  id         String        @id @default(uuid())
  districtId String        @map("district_id")
  district   CrmDistrict   @relation(fields: [districtId], references: [id], onDelete: Cascade)
  name       String        // e.g., "Route 12A"
  code       String        @unique
  repId      String?       @map("rep_id")
  rep        User?         @relation("RouteRepresentative", fields: [repId], references: [id])
  createdAt  DateTime      @default(now()) @map("created_at")
  retailers  CrmRetailer[]

  @@map("crm_routes")
}

model CrmChainAccount {
  id           String        @id @default(uuid())
  name         String        // e.g., "7-Eleven"
  code         String        @unique // e.g., "CHAIN-711"
  contactName  String?       @map("contact_name")
  contactPhone String?       @map("contact_phone")
  contactEmail String?       @map("contact_email")
  createdAt    DateTime      @default(now()) @map("created_at")
  retailers    CrmRetailer[]

  @@map("crm_chain_accounts")
}

model CrmRetailer {
  id                String           @id @default(uuid())
  externalId        String           @unique @map("external_id") // Durable CRM identification key
  name              String
  address           String
  city              String
  zipCode           String           @map("zip_code")
  phone             String?
  status            String           @default("active") // active, inactive, suspended
  applicationStatus String           @default("approved") @map("application_status") // pending, approved, terminated
  trainingStatus    String           @default("not_trained") @map("training_status") // not_trained, trained
  lastVisitDate     DateTime?        @map("last_visit_date")
  visitCadence      String           @default("weekly") @map("visit_cadence") // weekly, biweekly, monthly
  routeId           String?          @map("route_id")
  route             CrmRoute?        @relation(fields: [routeId], references: [id])
  routeOrder        Int              @default(0) @map("route_order")
  chainId           String?          @map("chain_id")
  chain             CrmChainAccount? @relation(fields: [chainId], references: [id])
  latitude          Float?
  longitude         Float?
  geodataBypassed   Boolean          @default(false) @map("geodata_bypassed")
  geodataStatus     String?          @map("geodata_status")
  geodataDistance   Float?           @map("geodata_distance")
  geodataLastChecked DateTime?       @map("geodata_last_checked")
  geodataHostCorrectionRequested Boolean @default(false) @map("geodata_host_correction_requested")
  geodataStandardAddress String?     @map("geodata_standard_address")
  geodataStandardLatitude Float?     @map("geodata_standard_latitude")
  geodataStandardLongitude Float?    @map("geodata_standard_longitude")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  assignments       CrmAssetAssignment[]
  visits            CrmVisit[]
  actionItems       CrmActionItem[]
  discrepancies     CrmDiscrepancyException[]

  @@map("crm_retailers")
}

model CrmEquipmentType {
  id          String     @id @default(uuid())
  code        String     @unique // e.g., "FLEX-TERMINAL"
  name        String     // e.g., "FLEX clerk terminal"
  category    String     // terminal, self_service_terminal, vending_machine, in_lane, peripheral, signage, fixture, infrastructure, security
  manufacturer String
  model       String
  isRegulated Boolean    @default(false) @map("is_regulated")
  createdAt   DateTime   @default(now()) @map("created_at")
  assets      CrmAsset[]

  @@map("crm_equipment_types")
}

model CrmAsset {
  id                    String               @id @default(uuid())
  serialNumber          String?              @unique @map("serial_number")
  assetTag              String?              @unique @map("asset_tag")
  typeId                String               @map("type_id")
  type                  CrmEquipmentType     @relation(fields: [typeId], references: [id])
  status                String               @default("active") // pending_install, active, missing, pending_retrieval, returned, decommissioned, unknown
  statusReason          String?              @map("status_reason")
  ownerType             String               @default("lottery_owned") @map("owner_type") // lottery_owned, retailer_owned, vendor_owned, leased, unknown
  networkRequired       Boolean              @default(false) @map("network_required")
  powerRequired         Boolean              @default(false) @map("power_required")
  supportsCashless      Boolean              @default(false) @map("supports_cashless")
  supportsTicketCheck   Boolean              @default(false) @map("supports_ticket_check")
  supportsDrawGames     Boolean              @default(false) @map("supports_draw_games")
  supportsInstantGames  Boolean              @default(false) @map("supports_instant_games")
  warrantyStartDate     DateTime?            @map("warranty_start_date") @db.Date
  warrantyEndDate       DateTime?            @map("warranty_end_date") @db.Date
  notes                 String?              @db.Text
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")
  assignments           CrmAssetAssignment[]

  @@map("crm_assets")
}

model CrmAssetAssignment {
  id             String          @id @default(uuid())
  retailerId     String          @map("retailer_id")
  retailer       CrmRetailer     @relation(fields: [retailerId], references: [id], onDelete: Cascade)
  assetId        String          @map("asset_id")
  asset          CrmAsset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  placementZone  String          @default("service_counter") @map("placement_zone") // queue_line, customer_service, service_counter, front_end, entry_lobby, travel_plaza_concourse, back_office, other
  installDate    DateTime?       @map("install_date") @db.Date
  removalDate    DateTime?       @map("removal_date") @db.Date
  sourceSystem   String          @default("manual_upload") @map("source_system") // api_read_only_source, vendor_export, manual_upload, survey_import, field_audit
  sourceAssetKey String?         @map("source_asset_key") // external primary identifier from upstream API
  integrationMode String         @default("manual_upload") @map("integration_mode") // api_read_only, vendor_export, manual_upload
  batchId        String?         @map("batch_id")
  batch          CrmImportBatch? @relation(fields: [batchId], references: [id])
  rowProvenance  String?         @map("row_provenance")
  createdAt      DateTime        @default(now()) @map("created_at")
  lastVerifiedAt DateTime?       @map("last_verified_at")

  verifications  CrmAssetVerification[]
  discrepancies  CrmDiscrepancyException[]

  @@map("crm_asset_assignments")
}

model CrmImportBatch {
  id           String               @id @default(uuid())
  domain       String               // retailer_master, user_territory, equipment_catalog, equipment_assignment
  fileName     String               @map("file_name")
  status       String               @default("success") // success, failed
  importedById String               @map("imported_by_id")
  importedBy   User                 @relation(fields: [importedById], references: [id])
  rowCount     Int                  @map("row_count")
  errorCount   Int                  @map("error_count")
  changes      Json?                @default("{}")
  createdAt    DateTime             @default(now()) @map("created_at")
  assignments  CrmAssetAssignment[]

  @@map("crm_import_batches")
}

model CrmVisit {
  id            String      @id @default(uuid())
  retailerId    String      @map("retailer_id")
  retailer      CrmRetailer @relation(fields: [retailerId], references: [id], onDelete: Cascade)
  userId        String      @map("user_id")
  user          User        @relation(fields: [userId], references: [id])
  visitDate     DateTime    @map("visit_date") @db.Date
  status        String      @default("completed") // planned, completed
  checkInTime   DateTime?   @map("check_in_time")
  checkOutTime  DateTime?   @map("check_out_time")
  syncStatus    String      @default("synced") @map("sync_status") // queued, synced
  notes         String?     @db.Text
  createdAt     DateTime    @default(now()) @map("created_at")

  coaching      CrmCoaching?
  merchandising CrmMerchandising?
  process       CrmProcessImprovement?
  verifications CrmAssetVerification[]
  actionItems   CrmActionItem[]
  exceptions    CrmDiscrepancyException[]

  @@map("crm_visits")
}

model CrmCoaching {
  id                    String   @id @default(uuid())
  visitId               String   @unique @map("visit_id")
  visit                 CrmVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  askForTheSaleTrained  Boolean  @default(false) @map("ask_for_the_sale_trained")
  personnelTrainedCount Int      @default(0) @map("personnel_trained_count")
  coachingFeedback      String?  @map("coaching_feedback") @db.Text
  actionPlan            String?  @map("action_plan") @db.Text

  @@map("crm_coaching_logs")
}

model CrmMerchandising {
  id                       String   @id @default(uuid())
  visitId                  String   @unique @map("visit_id")
  visit                    CrmVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  dispensersCleanAndFilled Boolean  @default(false) @map("dispensers_clean_and_filled")
  posSignageVisible        Boolean  @default(false) @map("pos_signage_visible")
  ticketInventoryAdequate  Boolean  @default(false) @map("ticket_inventory_adequate")
  merchandisingFeedback    String?  @map("merchandising_feedback") @db.Text

  @@map("crm_merchandising_logs")
}

model CrmProcessImprovement {
  id                   String   @id @default(uuid())
  visitId              String   @unique @map("visit_id")
  visit                CrmVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  salesTrendReviewed   Boolean  @default(false) @map("sales_trend_reviewed")
  outOfStockPrevented  Boolean  @default(false) @map("out_of_stock_prevented")
  optimalLayoutApplied Boolean  @default(false) @map("optimal_layout_applied")
  improvementFeedback  String?  @map("improvement_feedback") @db.Text
  targetSalesGrowth    Decimal? @map("target_sales_growth") @db.Decimal(5, 2)

  @@map("crm_process_improvement_logs")
}

model CrmAssetVerification {
  id                 String             @id @default(uuid())
  visitId            String             @map("visit_id")
  visit              CrmVisit           @relation(fields: [visitId], references: [id], onDelete: Cascade)
  assetAssignmentId  String             @map("asset_assignment_id")
  expectedAssignment CrmAssetAssignment @relation(fields: [assetAssignmentId], references: [id], onDelete: Cascade)
  observedStatus     String             // present, missing, incorrect_placement
  isDisputed         Boolean            @default(false) @map("is_disputed")
  notes              String?            @db.Text
  createdAt          DateTime           @default(now()) @map("created_at")

  @@map("crm_asset_verifications")
}

model CrmDiscrepancyException {
  id                String              @id @default(uuid())
  retailerId        String              @map("retailer_id")
  retailer          CrmRetailer         @relation(fields: [retailerId], references: [id], onDelete: Cascade)
  visitId           String?             @map("visit_id")
  visit             CrmVisit?           @relation(fields: [visitId], references: [id])
  assetAssignmentId String?             @map("asset_assignment_id")
  expectedAssignment CrmAssetAssignment? @relation(fields: [assetAssignmentId], references: [id])
  title             String              // e.g. "Missing Flex Terminal serial SN-4819"
  description       String              @db.Text
  status            String              @default("open") // open, resolved
  resolvedAt        DateTime?           @map("resolved_at")
  resolvedById      String?             @map("resolved_by_id")
  resolvedBy        User?               @relation("DiscrepancyResolver", fields: [resolvedById], references: [id])
  createdAt         DateTime            @default(now()) @map("created_at")

  @@map("crm_discrepancy_exceptions")
}

model CrmActionItem {
  id          String      @id @default(uuid())
  retailerId  String      @map("retailer_id")
  retailer    CrmRetailer @relation(fields: [retailerId], references: [id], onDelete: Cascade)
  visitId     String?     @map("visit_id")
  visit       CrmVisit?   @relation(fields: [visitId], references: [id])
  title       String
  description String      @db.Text
  status      String      @default("open") // open, completed
  dueDate     DateTime?   @map("due_date") @db.Date
  createdAt   DateTime    @default(now()) @map("created_at")

  @@map("crm_action_items")
}
