model TrialBalanceRecord {
  id             String       @id @default(uuid())
  jurisdictionId String       @map("jurisdiction_id")
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id])
  uploadId       String?      @map("upload_id") // Links to ImportBatch for atomic rollback
  upload         ImportBatch? @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  fiscalYear     Int          @map("fiscal_year") // e.g. 2024
  periodCode     String       @map("period_code") // "P01" to "P12", "P13" (EOY), "Q01" to "Q04"
  periodDate     DateTime     @map("period_date") @db.Date // Standardized date for R/Shiny compatibility
  accountCode    String       @map("account_code")
  accountName    String       @map("account_name")
  balance        Decimal      @db.Decimal(14, 2)
  status         String       @default("imported") // imported, adjusted, archived
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([jurisdictionId, fiscalYear, periodCode])
  @@map("trial_balance_records")
}

model GasbRow {
  id                String       @id @default(uuid())
  jurisdictionId    String       @map("jurisdiction_id")
  jurisdiction      Jurisdiction @relation(fields: [jurisdictionId], references: [id])
  statement         String       // "netPosition", "revenuesExpenses", "cashFlows"
  section           String       // e.g. "currentAssets", "operatingExpenses"
  label             String
  accountPattern    String       @map("account_pattern") // e.g. "1-1000" or "5-2000,5-2100"
  rowType           String       @map("row_type") // "data", "subtotal", "total"
  signageMultiplier Decimal      @default(1.0) @map("signage_multiplier") @db.Decimal(3, 1)
  sortOrder         Int          @map("sort_order")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  @@map("gasb_rows")
}

model ReportTemplate {
  id             String       @id @default(uuid())
  jurisdictionId String       @map("jurisdiction_id")
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id])
  name           String
  description    String?      @db.Text
  content        String       @db.Text // Markdown with {{ TAG }}
  createdById    String       @map("created_by")
  createdBy      User         @relation(fields: [createdById], references: [id])
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  snapshots ReportSnapshot[]

  @@map("report_templates")
}

model ReportSnapshot {
  id          String         @id @default(uuid())
  templateId  String         @map("template_id")
  template    ReportTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  periodDate  DateTime       @map("period_date") @db.Date
  contentHtml String         @map("content_html") @db.Text
  status      String         @default("draft") // draft, reviewed, approved, published
  createdById String         @map("created_by")
  createdBy   User           @relation(fields: [createdById], references: [id])
  createdAt   DateTime       @default(now()) @map("created_at")

  @@map("report_snapshots")
}

model ReportPackage {
  id             String       @id @default(uuid())
  jurisdictionId String       @map("jurisdiction_id")
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id])
  name           String       // "FY24 Q3 ACFR"
  frequency      String       @default("annual") // annual, quarterly, monthly
  periodDate     DateTime     @map("period_date") @db.Date
  status         String       @default("draft") // draft, in_review, approved, published
  createdById    String       @map("created_by")
  createdBy      User         @relation(fields: [createdById], references: [id])
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  sections          ReportSection[]
  commentaryTasks   CommentaryTask[]
  budgetScenarios   BudgetScenario[]
  evidence          SupportingEvidence[]
  compiledArtifacts CompiledArtifact[]

  @@map("report_packages")
}

model ReportSection {
  id             String         @id @default(uuid())
  packageId      String         @map("package_id")
  package        ReportPackage  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  name           String         // "Management Discussion & Analysis"
  content        String         @db.Text
  status         String         @default("draft") // draft, submitted, approved
  sortOrder      Int            @default(0) @map("sort_order")
  
  assigneeId     String?        @map("assignee_id")
  assignee       User?          @relation("SectionAssignee", fields: [assigneeId], references: [id])
  reviewerId     String?        @map("reviewer_id")
  reviewer       User?          @relation("SectionReviewer", fields: [reviewerId], references: [id])
  
  dueDate        DateTime?      @map("due_date") @db.Date
  submittedAt    DateTime?      @map("submitted_at")
  approvedAt     DateTime?      @map("approved_at")
  
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  commentaryTasks CommentaryTask[]
  evidence        SupportingEvidence[]

  @@map("report_sections")
}

