# =============================================================================
# Stochos Platform — Environment Configuration Template
# =============================================================================
# Copy this file to '.env.local' or '.env' and fill in your values.
# DO NOT commit the actual '.env.local' or '.env' files to Git repository!
# =============================================================================

# 1. Database Configuration
# Prisma connection string to your operational PostgreSQL database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# 2. Authentication (NextAuth)
# Generate a secure 32-character secret using: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-jwt-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# 3. External API Integrations
# Optional Census Bureau API key for multi-year demographic ingestion
CENSUS_API_KEY="your-us-census-api-key-here"

# 4. Routing Engine (OSRM)
# Base URL for the driving routing engine.
# Local development default uses the public OSRM server.
# For production, set to your private containerized OSRM VPC endpoint (e.g. http://10.0.x.x:5000)
OSRM_URL="http://router.project-osrm.org"
