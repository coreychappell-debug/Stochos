# Ingress routing for Stochos Platform & Analytics
stochosgroup.tail88cba8.ts.net {
    # 1. Enable automated HTTPS certificates via Tailscale
    tls {
        get_certificate tailscale
    }

    # 2. Production Shiny Server dashboards (Port 3838)
    # Accessible via: https://stochosgroup.tail88cba8.ts.net/shiny/
    reverse_proxy /shiny/* 127.0.0.1:3838 {
        # Enable sticky sessions for active dashboard metrics
        lb_policy cookie stochos_session
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up Connection "Upgrade"
        header_up Upgrade $http_upgrade
    }

    # 3. Production RStudio Servers (Corey, Tyler, Caitlin)
    # Redirects to ensure trailing slash
    redir /rstudio /rstudio/
    redir /rstudio-tyler /rstudio-tyler/
    redir /rstudio-caitlin /rstudio-caitlin/

    handle_path /rstudio/* {
        reverse_proxy 127.0.0.1:8787 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-RStudio-Root-Path "/rstudio"
        }
    }

    handle_path /rstudio-tyler/* {
        reverse_proxy 127.0.0.1:8788 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-RStudio-Root-Path "/rstudio-tyler"
        }
    }

    handle_path /rstudio-caitlin/* {
        reverse_proxy 127.0.0.1:8789 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-RStudio-Root-Path "/rstudio-caitlin"
        }
    }

    # 4. Next.js platform root (Port 3000) - Catch-all fallback
    handle {
        reverse_proxy 127.0.0.1:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }
}
